{
  "name": "tally-software",
  "private": true,
  "version": "1.3.2",
  "description": "Tally Software Desktop Application",
  "author": "Aditya Singh",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false vite build && electron-builder --win --publish never",
    "electron:dist": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "dbf-reader": "^1.0.3",
    "electron-updater": "^6.8.3",
    "fast-xml-parser": "^5.7.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^1.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.tally.software",
    "productName": "Tally Software",
    "copyright": "Copyright © 2024 Aditya Singh",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tally Software"
    },
    "publish": {
      "provider": "github",
      "owner": "your-username",
      "repo": "Tally-"
    }
  }
}
